params {
    // Required
    roster           = null   // roster CSV: genome_id, model_path (SBML/CarveMe GEMs)
    outdir           = './results'
    help             = false

    // Publishing
    publish_dir_mode = 'copy'

    // --- Seed data generation -------------------------------------------------
    num_shards          = 10      // HPC fan-out: communities split across this many `generate` tasks
    n_communities       = 200     // total communities sampled (the "large seed dataset" size knob)
    community_size_min  = 2
    community_size_max  = 6
    media_per_community = 40
    sampler             = 'perturb'  // perturb | sparse | dirichlet | lhs
    tradeoff            = 0.35
    max_uptake          = 1000.0
    solver              = 'hybrid'   // HiGHS via optlang (no CPLEX/Gurobi licence)
    seed                = 0

    // --- Active-learning supplementation --------------------------------------
    n_communities_augment = 20    // top-N communities (by feasible seed samples) to train/augment
    active_rounds         = 5     // discrete rounds per community (0 = skip, train on seed data)
    active_batch_size     = 16    // real solves per round
    active_n_candidates   = 2000  // media proposed per round
    active_n_models       = 5     // acquisition ensemble size
    active_hidden         = '256,256'
    active_epochs         = 1000  // max-epoch cap; training early-stops
    n_active              = 20    // sparse sampler: active components per medium

    // --- Model sweep ----------------------------------------------------------
    // Swept dimensions (list syntax mirrors the reference: ',' items, ';' arch specs).
    hidden_configs = '256,256;512,512,512'  // architectures: widths per layer
    n_models_list  = '3,5'                   // ensemble sizes
    train_sizes    = '200,500,1000'          // --n-train caps (learning curve)
    train_epochs   = 1000  // max-epoch cap; training early-stops
    test_size      = 0.2

    // Resource limits (overridden by HPC/cloud profiles)
    max_cpus   = 16
    max_memory = '128.GB'
    max_time   = '240.h'
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    conda {
        conda.enabled = true
    }
}

manifest {
    name            = 'surrogate-mgem'
    description     = 'HPC training sweep for learned surrogate metabolic models (data generation, active learning, architecture/ensemble/data-size sweep)'
    version         = '0.1.0'
    nextflowVersion = '>=25.0'
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.txt"
    overwrite = false
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
    overwrite = false
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
    overwrite = false
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
    overwrite = false
}
