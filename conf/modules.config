// Per-process tool arguments (ext.args) and publishing. Modules stay generic;
// dataset-specific behaviour is params -> ext.args here, matching the reference.
process {
    publishDir = [ enabled: false ]

    withName: 'GENERATE_DATA' {
        ext.args = "--n-communities ${params.n_communities} " +
            "--size-min ${params.community_size_min} --size-max ${params.community_size_max} " +
            "--media-per-community ${params.media_per_community} --sampler ${params.sampler} " +
            "--n-active ${params.n_active} --tradeoff ${params.tradeoff} " +
            "--max-uptake ${params.max_uptake} --solver ${params.solver} --seed ${params.seed}"
    }

    withName: 'ACTIVE_LEARN' {
        ext.args = "--batch-size ${params.active_batch_size} --n-candidates ${params.active_n_candidates} " +
            "--sampler ${params.sampler} --n-active ${params.n_active} " +
            "--n-models ${params.active_n_models} --hidden ${params.active_hidden} " +
            "--epochs ${params.active_epochs} --max-uptake ${params.max_uptake} " +
            "--tradeoff ${params.tradeoff} --solver ${params.solver} --seed ${params.seed}"
    }

    withName: 'TRAIN_SURROGATE' {
        ext.args   = "--epochs ${params.train_epochs} --test-size ${params.test_size} --seed ${params.seed}"
        publishDir = [
            path:    { "${params.outdir}/models" },
            mode:    params.publish_dir_mode,
            saveAs:  { fn -> fn.equals('versions.yml') ? null : fn },
        ]
    }

    withName: 'COLLECT_METRICS' {
        publishDir = [
            path:    { "${params.outdir}" },
            mode:    params.publish_dir_mode,
            pattern: 'leaderboard.csv',
        ]
    }
}
