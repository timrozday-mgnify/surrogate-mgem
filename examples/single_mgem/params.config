// Params for the single-mGEM example (see README.md). Every value below is a
// default from nextflow.config unless the comment says otherwise; the comments
// mark the ones you are most likely to want to change.

params {
    // --- seed data generation -------------------------------------------------
    num_shards          = 1     // CHANGE ON HPC: parallel `generate` tasks (e.g. 10). 1 is right for a laptop.
    n_communities       = 1     // one genome -> exactly one possible community, so 1
    community_size_min  = 1     // must be 1 here; larger needs more genomes in roster.csv
    community_size_max  = 1     // ditto
    media_per_community = 300   // MAIN DATASET-SIZE KNOB: training rows. More = better fit, more solver time.
    sampler             = 'sparse'  // sparse|perturb|dirichlet|lhs. sparse = limiting media, best signal for one organism.
    n_active            = 20    // non-zero nutrients per medium (sparse sampler only). Lower = harsher media.
    tradeoff            = 0.35  // MICOM cooperative tradeoff; no effect with a single member
    max_uptake          = 1000.0
    solver              = 'hybrid'  // HiGHS. Only change if you have a CPLEX/Gurobi licence.
    seed                = 0     // change to get a different (but reproducible) dataset

    // --- active-learning supplementation --------------------------------------
    n_communities_augment = 1   // cannot exceed the number of communities (1 here)
    active_rounds         = 3   // SET TO 0 for the fastest run (seed data only, no active learning)
    active_batch_size     = 16  // real MICOM solves per round -> +48 rows total at 3 rounds
    active_n_candidates   = 2000  // media proposed per round (cheap: only the surrogate scores them)
    active_n_models       = 5     // acquisition ensemble size
    active_hidden         = '256,256'
    active_epochs         = 1000  // cap only; training early-stops

    // --- model sweep ----------------------------------------------------------
    // One TRAIN_SURROGATE task per architecture x ensemble size x train size.
    // As set: 2 x 1 x 2 = 4 tasks. Add items to widen the sweep.
    hidden_configs = '128,128;256,256'  // ';' between architectures, ',' between layer widths
    n_models_list  = '3'                // ensemble sizes
    train_sizes    = '100,300'          // --n-train caps (learning curve). Keep <= rows actually generated.
    train_epochs   = 1000  // cap only; training early-stops
    test_size      = 0.2

    // --- resource ceilings ----------------------------------------------------
    // Sized for a laptop. On a cluster, raise these and add the executor with
    // `-c site.config` (this repo ships no slurm profile).
    max_cpus   = 8
    max_memory = '16.GB'
    max_time   = '8.h'
}

